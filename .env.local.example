# Copia in .env.local per test in locale con `vercel dev`.
# In produzione questi valori vanno impostati nelle Environment Variables di Vercel.

# Connection string di Neon (SQL Editor → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/segnalazioni?sslmode=require

# Email con cui accedere all'app (una sola)
AUTH_EMAIL=marioisernia@gmail.com

# Password di accesso
AUTH_PASSWORD=cambia_questa_password

# Stringa random per firmare le sessioni (min 32 caratteri).
# Puoi generarla con: openssl rand -base64 48
SESSION_SECRET=metti_qui_una_stringa_random_lunga_almeno_32_caratteri_aaaaa
